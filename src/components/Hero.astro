---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="relative px-6 pb-20 pt-36 text-white md:pb-28 md:pt-44">
  <div class="container mx-auto max-w-5xl text-center">
    <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-slate-950/92 shadow-2xl shadow-slate-950/40">
      <div class="bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.28),transparent_34%),linear-gradient(135deg,rgba(7,11,24,0.98),rgba(15,23,42,0.96))] px-8 py-12 md:px-14 md:py-16">
        <p class="mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-blue-200/80">LogicLabs Network</p>
        <h1 class="mb-6 text-4xl font-extrabold tracking-tight text-white md:text-5xl lg:text-6xl">
          Transformišemo ideje u web proizvode koji izgledaju premium i donose rezultate.
        </h1>
        <p class="mx-auto mb-8 max-w-3xl text-lg leading-8 text-slate-200 md:text-xl">
          Dizajniramo i razvijamo moderne sajtove, prodavnice i web aplikacije sa fokusom na brzinu,
          korisničko iskustvo i dugoročnu održivost.
        </p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href={`${base}/kontakt`} class="rounded-full bg-white px-7 py-3 font-semibold text-slate-950 shadow-xl shadow-slate-950/30 transition hover:-translate-y-0.5 hover:bg-slate-100">
            Zatražite ponudu
          </a>
          <a href={`${base}/portfolio`} class="rounded-full border border-white/20 bg-slate-900 px-7 py-3 font-semibold text-white transition hover:-translate-y-0.5 hover:bg-slate-800">
            Pogledajte portfolio
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
