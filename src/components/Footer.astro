---
import logoImage from '../assets/logo.svg';

const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const footerColumns = [
  {
    title: 'Usluge',
    links: [
      { label: 'Izrada web sajtova', href: '/usluge/izrada-web-sajtova' },
      { label: 'Web dizajn', href: '/usluge/web-dizajn' },
      { label: 'Programiranje', href: '/usluge/programiranje' },
      { label: 'SEO optimizacija', href: '/usluge/seo-optimizacija' },
      { label: 'Cenovnik', href: '/usluge/cenovnik' },
    ],
  },
  {
    title: 'Portfolio',
    links: [
      { label: 'Svi projekti', href: '/portfolio' },
      { label: 'Inovatech Solutions', href: '/portfolio/inovatech-solutions' },
      { label: 'Crafty Corner', href: '/portfolio/crafty-corner' },
      { label: 'BookItNow', href: '/portfolio/bookitnow' },
      { label: 'Data Dashboard', href: '/portfolio/data-dashboard' },
    ],
  },
  {
    title: 'Kompanija',
    links: [
      { label: 'O nama', href: '/o-nama' },
      { label: 'Kontakt', href: '/kontakt' },
      { label: 'Početna', href: '/' },
    ],
  },
];

const socialLinks = [
  { href: 'https://www.youtube.com/@the_serbian_king_mlbb', label: 'YouTube', iconPath: 'M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z' },
  { href: 'https://www.tiktok.com/@the_serbian_king_mlbb', label: 'TikTok', iconPath: 'M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z' },
  { href: 'https://github.com/UnlimitedEdition', label: 'GitHub', iconPath: 'M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.91 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z' },
];
---

<footer class="mt-16 border-t border-white/8 bg-slate-950/98 text-white">
  <div class="container mx-auto px-6 py-14">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_repeat(3,1fr)]">
      <div class="max-w-sm">
        <a href={`${base}/`} aria-label="LogicLabs Network početna" class="inline-flex items-center">
          <img src={logoImage.src} alt="LogicLabs Network logo" class="h-10 w-auto drop-shadow-[0_0_10px_rgba(255,255,255,0.18)]" />
        </a>
        <p class="mt-5 text-sm leading-7 text-slate-300">
          LogicLabs Network dizajnira i razvija moderne web sajtove, online prodavnice i aplikacije sa fokusom na brzinu, kredibilitet i rezultate.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={`${base}/kontakt`} class="inline-flex rounded-full bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-blue-500">
            Zatražite ponudu
          </a>
          <a href={`${base}/portfolio`} class="inline-flex rounded-full border border-white/12 bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800">
            Portfolio
          </a>
        </div>
      </div>

      {footerColumns.map((column) => (
        <nav aria-label={column.title}>
          <h3 class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-400">{column.title}</h3>
          <ul class="mt-5 space-y-3">
            {column.links.map((link) => (
              <li>
                <a href={base + link.href} class="text-sm text-slate-300 transition hover:text-white">{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <div class="mt-12 flex flex-col gap-6 border-t border-white/8 pt-6 md:flex-row md:items-center md:justify-between">
      <p class="text-sm text-slate-400">© {currentYear} LogicLabs Network. Sva prava zadržana.</p>
      <div class="flex items-center gap-3">
        {socialLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label} class="inline-flex rounded-full border border-white/10 bg-slate-900 p-3 text-slate-300 transition hover:-translate-y-0.5 hover:bg-slate-800 hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d={link.iconPath} />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
