---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="px-6 pt-32 pb-10 text-white md:pt-36 md:pb-14">
  <div class="container mx-auto">
    <div class="overflow-hidden rounded-[2rem] border border-white/8 bg-slate-950/92 shadow-2xl shadow-slate-950/30">
      <div class="bg-[radial-gradient(circle_at_top,rgba(59,130,246,0.22),transparent_32%),linear-gradient(135deg,rgba(7,11,24,0.98),rgba(15,23,42,0.96))] px-8 py-12 text-center md:px-12 md:py-16">
        <h1 class="text-4xl font-bold text-white md:text-5xl">{title}</h1>
        {subtitle && <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-200 md:text-xl">{subtitle}</p>}
      </div>
    </div>
  </div>
</section>
