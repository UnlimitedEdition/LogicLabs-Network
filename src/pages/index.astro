---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import IconWebDev from '../components/icons/IconWebDev.astro';
import IconWebDesign from '../components/icons/IconWebDesign.astro';
import IconSeo from '../components/icons/IconSeo.astro';

const base = import.meta.env.BASE_URL || '';

const featuredServices = [
  { id: 'web-dev', title: 'Izrada Web Sajtova', description: 'Moderni, brzi i responzivni sajtovi prilagođeni vašim poslovnim ciljevima.', url: '/usluge/izrada-web-sajtova', IconComponent: IconWebDev },
  { id: 'web-design', title: 'Web Dizajn', description: 'Vizuelna rešenja koja grade poverenje i ostavljaju profesionalan prvi utisak.', url: '/usluge/web-dizajn', IconComponent: IconWebDesign },
  { id: 'seo', title: 'SEO Optimizacija', description: 'Jačamo vidljivost sajta i pomažemo da vas pravi klijenti lakše pronađu.', url: '/usluge/seo-optimizacija', IconComponent: IconSeo },
];

const featuredProjects = [
  {
    id: 'inovatech-solutions',
    title: 'Korporativni Sajt "Inovatech Solutions"',
    description: 'Moderan korporativni sajt za predstavljanje usluga, kredibiliteta i jasnih CTA tačaka.',
    imageUrl: '/images/portfolio-project-1.jpg',
    liveUrl: '/portfolio/inovatech-solutions',
  },
  {
    id: 'crafty-corner',
    title: 'E-commerce Platforma "Crafty Corner"',
    description: 'Online prodavnica osmišljena da jasno predstavi proizvode i pojednostavi kupovinu.',
    imageUrl: '/images/portfolio-project-2.jpg',
    liveUrl: '/portfolio/crafty-corner',
  },
  {
    id: 'bookitnow',
    title: 'Web Aplikacija za Rezervacije "BookItNow"',
    description: 'Sistem za online rezervacije sa fokusom na brz korisnički tok i preglednost.',
    imageUrl: '/images/portfolio-project-3.jpg',
    liveUrl: '/portfolio/bookitnow',
  },
];
---

<Layout>
  <Header />
  <main class="relative text-white">
    <Hero />

    <section class="surface-section py-16 md:py-20">
      <div class="container mx-auto px-6">
        <div class="rounded-[2rem] border border-white/8 bg-slate-950 px-8 py-12 text-center shadow-2xl shadow-slate-950/25 md:px-10 md:py-14">
          <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">Naše ključne usluge</h2>
          <p class="mx-auto mb-10 max-w-2xl text-slate-300">
            Fokusirani smo na rešenja koja izgledaju ozbiljno, rade brzo i ostavljaju jak utisak na klijente.
          </p>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {featuredServices.map(service => {
              const { IconComponent } = service;
              return (
                <a href={base + service.url} class="surface-panel group block rounded-2xl p-8 text-left no-underline transition hover:-translate-y-1 hover:shadow-xl">
                  <IconComponent />
                  <h3 class="mb-3 mt-5 text-xl font-semibold text-white transition-colors duration-300 group-hover:text-blue-300">{service.title}</h3>
                  <p class="text-slate-300">{service.description}</p>
                </a>
              );
            })}
          </div>

          <div class="mt-10">
            <a href={base + '/usluge'} class="inline-flex rounded-full bg-blue-600 px-6 py-3 font-semibold text-white transition hover:bg-blue-500">
              Pogledajte sve usluge
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="container mx-auto px-6">
        <div class="rounded-[2rem] border border-white/8 bg-slate-950 px-8 py-12 text-center shadow-2xl shadow-slate-950/25 md:px-10 md:py-14">
          <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">Istaknuti projekti</h2>
          <p class="mx-auto mb-10 max-w-2xl text-slate-300">
            Nekoliko primera radova koji pokazuju kako pristupamo dizajnu, strukturi sadržaja i korisničkom iskustvu.
          </p>

          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {featuredProjects.map((project, index) => (
              <a href={base + project.liveUrl} class="surface-panel group block overflow-hidden rounded-2xl text-left no-underline transition hover:-translate-y-1 hover:shadow-xl" data-aos="fade-up" data-aos-delay={index * 100}>
                <img src={base + project.imageUrl} alt={project.title} class="h-48 w-full object-cover" />
                <div class="border-t border-white/8 p-6">
                  <h3 class="mb-2 text-lg font-semibold text-white transition-colors duration-300 group-hover:text-blue-300">{project.title}</h3>
                  <p class="text-sm text-slate-300">{project.description}</p>
                </div>
              </a>
            ))}
          </div>

          <div class="mt-10">
            <a href={base + '/portfolio'} class="inline-flex rounded-full border border-white/15 bg-slate-900 px-6 py-3 font-semibold text-white transition hover:bg-slate-800">
              Pogledajte ceo portfolio
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="surface-section py-20">
      <div class="container mx-auto px-6">
        <div class="mx-auto max-w-4xl rounded-[2rem] border border-white/8 bg-slate-950 px-8 py-12 text-center shadow-2xl shadow-slate-950/25 md:px-12">
          <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">Spremni da započnemo vaš projekat?</h2>
          <p class="mx-auto mb-8 max-w-2xl text-lg text-slate-300">
            Bilo da vam treba novi sajt, redizajn ili kompletna web aplikacija, možemo da osmislimo rešenje koje izgleda ozbiljno i radi pouzdano.
          </p>
          <a href={base + '/kontakt'} class="inline-flex rounded-full bg-white px-8 py-3 text-lg font-bold text-slate-950 transition hover:bg-slate-100">
            Zatražite ponudu
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
